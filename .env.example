# ── PostgreSQL ──
POSTGRES_DB=cyberlens
POSTGRES_USER=cyberlens
POSTGRES_PASSWORD=cyberlens_dev
DATABASE_URL=postgresql://cyberlens:cyberlens_dev@db:5432/cyberlens

# ── Redis ──
REDIS_URL=redis://redis:6379/0

# ── Django ──
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,backend

# ── Nginx log monitoring ──
NGINX_LOG_PATH=/var/log/nginx/access.json

# ── CORS ──
CORS_ALLOWED_ORIGINS=http://localhost:5173

# ── Django Admin (auto-created on first startup) ──
DJANGO_SUPERUSER_USERNAME=admin
DJANGO_SUPERUSER_EMAIL=admin@cyberlens.local
DJANGO_SUPERUSER_PASSWORD=changeme123
